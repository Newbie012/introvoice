{
  "name": "introvice-v2",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "pnpm tsup index.ts --format esm --sourcemap",
    "dev": "tsx --watch index.ts",
    "start": "node dist/index.js",
    "docker:build": "docker build --target production -t introvoice:latest .",
    "docker:build-dev": "docker build -f Dockerfile.dev -t introvoice:dev .",
    "docker:run": "docker-compose up",
    "docker:run-dev": "docker-compose --profile dev up app-dev",
    "docker:stop": "docker-compose down",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Add linting when ready'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.18.0",
    "@js-joda/core": "^5.6.5",
    "@sentry/node": "^10.3.0",
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.1",
    "firebase-admin": "^13.4.0",
    "libsodium-wrappers": "^0.7.15",
    "type-fest": "^4.41.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "24.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
